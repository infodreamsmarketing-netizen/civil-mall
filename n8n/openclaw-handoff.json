      "parameters": {
        "jsCode": "const row = $input.first().json;\n\n// Clean phone number â€” strip non-digits, ensure 977 prefix\nlet phone = (row.WhatsApp || row.Phone || '').replace(/\\D/g, '');\nif (phone.startsWith('0')) phone = '977' + phone.slice(1);\nif (!phone.startsWith('977')) phone = '977' + phone;\nconst waNumber = phone + '@s.whatsapp.net';\n\n// Space info â€” handle blank (chatbot leads)\nconst spaceName = row.Space && row.Space.trim() ? row.Space.trim() : null;\nconst priceLabel = row.Price && row.Price.trim() ? row.Price.trim() : null;\nconst clientName = row.Name && row.Name.trim() ? row.Name.trim() : 'ji';\n\nlet message;\nif (spaceName) {\n  message = `Namaste ${clientName}! ðŸ™\\n\\nThank you for your interest in *${spaceName}* at The Kathmandu Mall, Sundhara.\\n\\nI'm Priya from *Dreams Media & Marketing*. Is this a good time to discuss this advertising opportunity?\\n\\nðŸ“ Space: ${spaceName}\\n${priceLabel ? 'ðŸ’° Rate: ' + priceLabel + '\\n' : ''}\\nWe'd love to help your brand get maximum visibility at one of Kathmandu's busiest malls! ðŸ˜Š`;\n} else {\n  message = `Namaste ${clientName}! ðŸ™\\n\\nThank you for reaching out to *Dreams Media & Marketing* â€” The Kathmandu Mall advertising partner.\\n\\nI'm Priya. I saw you were exploring our advertising spaces. Which space caught your eye? I can share full details and pricing right away! ðŸ˜Š`;\n}\n\nreturn [{\n  json: {\n    waNumber,\n    message,\n    clientName,\n    spaceName,\n    rowNumber: row._rowNumber,\n    sheetId: process.env.1HxyzZNhmPXU3LLjk1STczPQFA4XMktWsruQ6MmKXHJc\n  }\n}];\n"
      },
